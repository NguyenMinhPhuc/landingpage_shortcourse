# Example SQL Server connection (copy to .env and fill values)
DB_USER=sa
DB_PASSWORD=YourStrong!Pass
DB_SERVER=localhost
DB_DATABASE=Training
DB_PORT=1433
# Set to 'true' if using Azure SQL or encrypted connection
DB_ENCRYPT=false

# Simple admin token to protect admin API endpoints. Set to a strong random value.
ADMIN_TOKEN=changeme
